# ── Database ──────────────────────────────────────────────────────────────────
# Required for production. Leave unset to use local file-based fallback (dev).
DATABASE_URL="postgres://user:password@host:5432/dbname"

# ── File / Blob Storage ───────────────────────────────────────────────────────
ZIP_STORAGE_PROVIDER="vercel_blob"
ZIP_STORAGE_BUCKET="marketplace-assets"
ZIP_PUBLIC_BASE_URL="https://example-assets-cdn.com"
BLOB_READ_WRITE_TOKEN=""

# ── Auth ──────────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET="change-me-in-production"
# NEXTAUTH_URL="https://your-domain.com"

# ── Admin ─────────────────────────────────────────────────────────────────────
# ADMIN_API_SECRET="change-me"   # Optional: used to protect /api/admin/* routes

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
